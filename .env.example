# Zoho Mail OAuth2 — https://api-console.zoho.com/
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token

# Zoho data center region: com / eu / in / com.au / jp
ZOHO_REGION=com

# Account email to monitor
ZOHO_ACCOUNT_EMAIL=you@yourdomain.com

# Storage warning threshold (percent, 0-100)
STORAGE_WARN_PERCENT=80

# Backup output directory (absolute path)
BACKUP_DIR=./backups

# How often monitor.py polls (seconds)
POLL_SECONDS=60

# Optional: push monitor alerts to Slack/Discord/Telegram/any webhook
# Leave blank to disable. Payload sent as JSON {"text": "..."}
NOTIFY_WEBHOOK=

# ── ChatGPT Custom GPT integration (api_server.py) ──
# Secret that ChatGPT must send as "Authorization: Bearer <API_KEY>"
API_KEY=
# Your public tunnel URL (e.g. from cloudflared/ngrok) — no trailing slash
PUBLIC_URL=
# Port for the local API server
PORT=8000
